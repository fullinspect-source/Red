<Window x:Class="InspectionEditor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="330" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
        
        <TextBlock Grid.Row="1" Text="Gemini API Key:" FontSize="14" Margin="0,0,0,5"/>
        
        <TextBox x:Name="ApiKeyTextBox" Grid.Row="2" FontSize="14" Padding="8" Margin="0,0,0,10"/>
        
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <CheckBox x:Name="SuppressAdminToolsCheckBox"
                      Content="Suppress extra tools for administrative Section 1 items"
                      FontSize="14"
                      IsChecked="True"
                      Margin="0,6,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                <TextBlock Text="Default AI tone:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="DefaultAiToneComboBox" Width="150" Height="30" FontSize="14">
                    <ComboBoxItem Content="Technical"/>
                    <ComboBoxItem Content="Nice"/>
                    <ComboBoxItem Content="Strict"/>
                </ComboBox>
            </StackPanel>
            <TextBlock TextWrapping="Wrap" Foreground="#7F8C8D" FontSize="12">
                When enabled, Section 1 opens value/status only by default. Use Standard Tools on an item to bring back the full drawer set for that prompt.
                <LineBreak/><LineBreak/>
                The API key is optional and is saved locally for AI-powered inspection suggestions.
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="_Cancel" Width="100" Margin="5" Click="CancelButton_Click" IsCancel="True"/>
            <Button Content="_Save" Width="100" Margin="5" Click="SaveButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
