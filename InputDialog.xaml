<Window x:Class="InspectionEditor.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Width="520"
        MinHeight="185"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="24,20,24,20">
        <TextBlock x:Name="PromptText"
                   Text="Enter value:"
                   Margin="0,0,0,14"
                   TextWrapping="Wrap"/>
        <TextBox x:Name="InputTextBox"
                 Margin="0,0,0,18"
                 MinHeight="36"
                 Padding="7"
                 VerticalContentAlignment="Center"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="75" Margin="0,0,10,0" Click="OkButton_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="75" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
