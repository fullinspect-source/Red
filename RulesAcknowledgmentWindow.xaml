<Window x:Class="InspectionEditor.RulesAcknowledgmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚠️ Inspection Rules - Acknowledgment Required" 
        Height="780" Width="620"
        MinHeight="500" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#FFF5F5">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="⚠️ IMPORTANT RULES FOR THIS INSPECTION" 
                       FontSize="18" FontWeight="Bold" Foreground="#8B0000"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="SubtitleText" 
                       Text="Please review and acknowledge each rule before proceeding"
                       FontSize="12" Foreground="#666" 
                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>
        
        <!-- Rules List -->
        <ScrollViewer x:Name="RulesScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15"
                      PreviewMouseDown="ScrollViewer_PreviewMouseDown"
                      PreviewMouseMove="ScrollViewer_PreviewMouseMove"
                      PreviewMouseUp="ScrollViewer_PreviewMouseUp">
            <StackPanel>
                <StackPanel x:Name="FreeReinspectionPanel" Margin="0,0,0,12" Visibility="Collapsed"/>
                <StackPanel x:Name="RulesPanel">
                    <!-- Rules added dynamically -->
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="AcknowledgeAllButton" 
                    Content="✓ I Acknowledge All Rules" 
                    Click="AcknowledgeAllButton_Click"
                    Background="#27AE60" Foreground="White" 
                    FontSize="14" FontWeight="Bold"
                    Padding="20,10" Margin="0,0,10,0"
                    IsEnabled="False"/>
            <Button x:Name="CancelButton" 
                    Content="_Cancel" 
                    Click="CancelButton_Click"
                    Background="#E74C3C" Foreground="White"
                    FontSize="14" Padding="20,10"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
