<Window x:Class="InspectionEditor.FactCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Fact Check"
        Width="760"
        MinWidth="560"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F6F7F8"
        FontFamily="Segoe UI"
        FontSize="16">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#D0D5DA"
                BorderThickness="1"
                CornerRadius="6"
                Padding="18">
            <ScrollViewer MaxHeight="520"
                          VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="MessageTextBlock"
                           TextWrapping="Wrap"
                           LineHeight="24"/>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="1"
                Content="OK"
                Width="120"
                Padding="18,8"
                Margin="0,18,0,0"
                HorizontalAlignment="Right"
                IsDefault="True"
                Click="OkButton_Click"/>
    </Grid>
</Window>
