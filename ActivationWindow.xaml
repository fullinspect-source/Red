<Window x:Class="InspectionEditor.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RED - Activation Required"
        Height="620" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1a1a2e">
    
    <Grid Margin="30,25,30,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="🔐 Activation Required" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Foreground="#e94560"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- Status Message -->
        <TextBlock Grid.Row="1" 
                   x:Name="StatusMessage"
                   Text="RED requires activation to run on this machine."
                   FontSize="14"
                   Foreground="#cccccc"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Margin="0,0,0,25"/>

        <!-- Machine ID Label -->
        <TextBlock Grid.Row="2" 
                   Text="Your Machine Code:"
                   FontSize="12"
                   Foreground="#888888"
                   Margin="0,0,0,5"/>

        <!-- Machine ID Display -->
        <Border Grid.Row="3" 
                Background="#0f0f1a" 
                BorderBrush="#333355" 
                BorderThickness="1" 
                CornerRadius="5"
                Padding="15,10"
                Margin="0,0,0,10">
            <TextBlock x:Name="MachineIdText"
                       Text="XXXX-XXXX-XXXX-XXXX"
                       FontSize="24"
                       FontFamily="Consolas"
                       FontWeight="Bold"
                       Foreground="#00ff88"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Copy Button -->
        <Button Grid.Row="4"
                x:Name="CopyButton"
                Content="📋 Copy Machine Code"
                Click="CopyButton_Click"
                Background="#333355"
                Foreground="White"
                BorderThickness="0"
                Padding="15,8"
                FontSize="14"
                Cursor="Hand"
                HorizontalAlignment="Center"
                Margin="0,0,0,25"/>

        <!-- Instructions -->
        <StackPanel Grid.Row="5" VerticalAlignment="Top" Margin="0,5,0,0">
            <TextBlock Text="To activate RED:"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#cccccc"
                       Margin="0,0,0,15"/>
            
            <TextBlock FontSize="13" Foreground="#999999" TextWrapping="Wrap" Margin="0,0,0,10">
                <Run Text="1. Copy your machine code above"/>
            </TextBlock>
            <TextBlock FontSize="13" Foreground="#999999" TextWrapping="Wrap" Margin="0,0,0,10">
                <Run Text="2. Send it to your administrator"/>
            </TextBlock>
            <TextBlock FontSize="13" Foreground="#999999" TextWrapping="Wrap" Margin="0,0,0,10">
                <Run Text="3. You'll receive a license.lic file"/>
            </TextBlock>
            <TextBlock FontSize="13" Foreground="#999999" TextWrapping="Wrap" Margin="0,0,0,10">
                <Run Text="4. Place it in the RED folder and restart"/>
            </TextBlock>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,30,0,0">
            
            <Button x:Name="BrowseButton"
                    Content="📂 I Have a License File..."
                    Click="BrowseButton_Click"
                    Background="#0f3460"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="20,12"
                    FontSize="14"
                    Cursor="Hand"
                    Margin="0,0,10,0"/>
            
            <Button x:Name="ExitButton"
                    Content="E_xit"
                    Click="ExitButton_Click"
                    Background="#444455"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="30,12"
                    FontSize="14"
                    Cursor="Hand"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
