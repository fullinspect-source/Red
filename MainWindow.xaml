<Window x:Class="InspectionEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RED - The Inspection Editor" Height="850" Width="1300"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        Activated="Window_Activated">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5,8"/>
        </Style>
        
        <Style x:Key="PrefixButton" TargetType="ToggleButton">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#3498DB"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SuffixButton" TargetType="ToggleButton">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#27AE60"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#1E8449"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="AddButton" TargetType="Button">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#DDD"/>
            <Setter Property="BorderBrush" Value="#AAA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="35"/>
        </Style>
        
        <Style x:Key="SavedCommentButton" TargetType="Button">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <Style x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Background" Value="#FFDDDD"/>
            <Setter Property="BorderBrush" Value="#CC0000"/>
            <Setter Property="Foreground" Value="#CC0000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="24"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="AISuggestionButton" TargetType="Button">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#FFF8E7"/>
            <Setter Property="BorderBrush" Value="#E67E22"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Menu Bar -->
        <Border Grid.Row="0" Background="#8B0000" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left: Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="OpenFileButton" Content="📂 _Open INS" Click="OpenFileButton_Click" Background="#A52A2A" Foreground="White" BorderThickness="0" TabIndex="100"/>
                    <Button x:Name="SaveFileButton" Content="💾 _Save" Click="SaveFileButton_Click" Background="#228B22" Foreground="White" BorderThickness="0" IsEnabled="False" TabIndex="101"/>
                    
                    <!-- Template Buttons -->
                    <Border Background="#555" Width="1" Margin="8,4" VerticalAlignment="Stretch"/>
                    <Button x:Name="ApplyTemplateButton" Content="📥 _Apply Template" Click="ApplyTemplateButton_Click" Background="#2E86AB" Foreground="White" BorderThickness="0" IsEnabled="False" ToolTip="Apply saved default values (Alt+A)" TabIndex="102"/>
                    <Button x:Name="SaveTemplateButton" Content="📤 Save _Template" Click="SaveTemplateButton_Click" Background="#A23B72" Foreground="White" BorderThickness="0" IsEnabled="False" ToolTip="Save current values as a template (Alt+T)" TabIndex="103"/>
                    
                    <!-- Settings button removed - API key set via settings.txt -->
                </StackPanel>
                
                <!-- Center: File info -->
                <TextBlock x:Name="FileNameText" Grid.Column="1" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="13" FontWeight="Bold"
                           Cursor="Hand" MouseLeftButtonUp="FileNameText_Click" ToolTip="Click: Global stats"
                           TextDecorations="Underline"/>
                
                <!-- Right: Address (Project/Neighborhood stats), Builder (Builder stats) & Inspector -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="AddressText" Foreground="#FFCCCC" VerticalAlignment="Center" Margin="10,0" FontSize="12" FontWeight="SemiBold"
                               Cursor="Hand" MouseLeftButtonUp="AddressText_Click" ToolTip="Click: Neighborhood stats"/>
                    <TextBlock Text="|" Foreground="#AA6666" VerticalAlignment="Center" x:Name="AddressDivider" Visibility="Collapsed"/>
                    <TextBlock x:Name="BuilderText" Foreground="#FFCCCC" VerticalAlignment="Center" Margin="10,0" FontSize="12"
                               Cursor="Hand" MouseLeftButtonUp="BuilderText_Click" ToolTip="Click: Builder stats"/>
                    <TextBlock Text="|" Foreground="#AA6666" VerticalAlignment="Center" x:Name="HeaderDivider" Visibility="Collapsed"/>
                    <TextBlock x:Name="InspectorText" Foreground="#FFCCCC" VerticalAlignment="Center" Margin="10,0" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Help button: overlaid on header row, pinned to top-right corner of window -->
        <Button x:Name="HelpButton" 
                Grid.Row="0"
                Content="?" 
                Click="HelpButton_Click"
                Background="#2E86AB"
                Foreground="White"
                FontSize="20"
                FontWeight="Bold"
                Padding="0"
                Width="36"
                Height="36"
                Margin="0,8,12,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                BorderThickness="0"
                ToolTip="Open Help Guide (F1)"
                TabIndex="999"/>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" x:Name="MainContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftColumn" Width="350" MinWidth="250" MaxWidth="900"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Draggable Splitter between left and right panes -->
            <GridSplitter x:Name="ChecklistGridSplitter"
                          Grid.Column="1" Width="15" 
                          Background="#BDC3C7" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Stretch"
                          Cursor="SizeWE"
                          DragCompleted="GridSplitter_DragCompleted"/>

            <!-- Left Column: Panel + Docs Button -->
            <Grid x:Name="ChecklistColumnGrid" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Left Panel - Sections and Items -->
                <Border Grid.Row="0" BorderBrush="#BDC3C7" BorderThickness="0,0,1,0" Background="#F5F5F5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="10,8" LastChildFill="True">
                            <TextBlock Text="Insp Items" Style="{StaticResource HeaderStyle}" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="InspectionTotalCounter" FontSize="13" Foreground="#787878"
                                       VerticalAlignment="Center" Margin="8,0,0,0" Visibility="Collapsed"
                                       DockPanel.Dock="Left"/>
                            <Border x:Name="InspectionTotalStar" Visibility="Collapsed"
                                    Background="#C8DCFF" BorderBrush="#4682DC" BorderThickness="1"
                                    CornerRadius="3" Padding="2,0,2,0" Margin="3,0,0,0" VerticalAlignment="Center"
                                    DockPanel.Dock="Left">
                                <TextBlock Text="⭐" FontSize="12"/>
                            </Border>
                            <!-- Trip number — docked right, set from filename -->
                            <TextBlock x:Name="TripNumberBadge"
                                       DockPanel.Dock="Right"
                                       Visibility="Collapsed"
                                       Style="{StaticResource HeaderStyle}"/>
                            <!-- MegaStats button — fills remaining center space -->
                            <Button x:Name="InlineEditorToggleButton"
                                    DockPanel.Dock="Right"
                                    Content="Inline"
                                    Click="InlineEditorToggleButton_Click"
                                    Background="#E8E8E8"
                                    Foreground="#333"
                                    BorderBrush="#CCC"
                                    BorderThickness="1"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Padding="8,4"
                                    Margin="8,0,0,0"
                                    ToolTip="Switch between classic checklist and inline row editor"
                                    IsTabStop="False"/>
                            <Button x:Name="TopTextSizeUpButton"
                                    DockPanel.Dock="Right"
                                    Content="A+"
                                    Click="TextSizeUp_Click"
                                    Background="#E8E8E8"
                                    Foreground="#333"
                                    BorderBrush="#CCC"
                                    BorderThickness="1"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Padding="8,4"
                                    Margin="6,0,0,0"
                                    ToolTip="Make checklist text bigger"
                                    IsTabStop="False"/>
                            <Button x:Name="TopTextSizeDownButton"
                                    DockPanel.Dock="Right"
                                    Content="A-"
                                    Click="TextSizeDown_Click"
                                    Background="#E8E8E8"
                                    Foreground="#333"
                                    BorderBrush="#CCC"
                                    BorderThickness="1"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Padding="8,4"
                                    Margin="6,0,0,0"
                                    ToolTip="Make checklist text smaller"
                                    IsTabStop="False"/>
                            <Border x:Name="MegaStatsButton"
                                    Visibility="Collapsed"
                                    Background="#1E40AF" CornerRadius="4"
                                    Padding="10,6" Margin="8,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    MouseDown="MegaStatsButton_MouseDown">
                                <TextBlock x:Name="MegaStatsButtonText"
                                           Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                            <Border x:Name="DesignExtractionButton"
                                    Visibility="Collapsed"
                                    Background="#0F766E" CornerRadius="4"
                                    Padding="10,6" Margin="0,0,8,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    MouseDown="DesignExtractionButton_MouseDown">
                                <TextBlock x:Name="DesignExtractionButtonText"
                                           Text="Design Extraction 0"
                                           Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </DockPanel>

                        <!-- MegaStats overlay — spans all 3 rows of the inner Grid -->
                        <Grid x:Name="MegaStatsOverlay"
                              Grid.Row="0" Grid.RowSpan="3"
                              Visibility="Collapsed"
                              Panel.ZIndex="10"
                              MouseDown="MegaStatsOverlay_MouseDown">
                            <!-- Semi-transparent backdrop -->
                            <Rectangle Fill="#CC000000"/>
                            <!-- Card -->
                            <Border Background="White" CornerRadius="8"
                                    Margin="10,10,10,10"
                                    MaxHeight="500"
                                    VerticalAlignment="Top">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Card header -->
                                    <Border Grid.Row="0" Background="#1E3A8A" CornerRadius="8,8,0,0" Padding="12,8">
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="Most Common Items — Team Stats"
                                                       Foreground="White" FontWeight="Bold" FontSize="13"
                                                       DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                            <TextBlock Text="✕" Foreground="White" FontSize="14"
                                                       DockPanel.Dock="Right" VerticalAlignment="Center"
                                                       Cursor="Hand"
                                                       MouseDown="MegaStatsOverlay_MouseDown"/>
                                        </DockPanel>
                                    </Border>
                                    <!-- Card body — scrollable item list -->
                                    <ScrollViewer x:Name="MegaStatsScrollViewer"
                                                  Grid.Row="1" VerticalScrollBarVisibility="Hidden"
                                                  MaxHeight="440" Padding="0,0,4,0"
                                                  PreviewMouseLeftButtonDown="MegaStatsScrollViewer_PreviewMouseLeftButtonDown"
                                                  PreviewMouseMove="MegaStatsScrollViewer_PreviewMouseMove"
                                                  PreviewMouseLeftButtonUp="MegaStatsScrollViewer_PreviewMouseLeftButtonUp">
                                        <StackPanel x:Name="MegaStatsCardPanel" Margin="10,8,10,10"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                    <!-- Search/Filter Box with filter buttons -->
                    <Grid Grid.Row="1" Margin="8,0,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search Box (no embedded button) -->
                        <Border Grid.Column="0" Background="White" BorderBrush="#CCC" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="8,0,4,0" FontSize="12" Foreground="#888"/>
                                <TextBox x:Name="SearchFilterBox"
                                         Grid.Column="1"
                                         BorderThickness="0"
                                         VerticalAlignment="Center"
                                         FontSize="12"
                                         Padding="4"
                                         TextChanged="SearchFilterBox_TextChanged"
                                         TabIndex="5"/>
                            </Grid>
                        </Border>

                        <!-- ALL (Clear Filters) Button -->
                        <Button x:Name="ClearSearchButton"
                                Grid.Column="1"
                                Content="ALL"
                                Click="ClearSearchButton_Click"
                                Background="White"
                                Foreground="#555"
                                FontWeight="Bold"
                                FontSize="11"
                                Padding="8,4"
                                Margin="12,0,0,0"
                                BorderBrush="#DC143C"
                                BorderThickness="3"
                                VerticalAlignment="Stretch"
                                ToolTip="Show all items (clear filters)"
                                TabIndex="6"/>

                        <!-- OFI (Only Fail Items) Toggle Button -->
                        <Button x:Name="OfiFilterButton"
                                Grid.Column="2"
                                Content="OFI"
                                Click="OfiFilterButton_Click"
                                Background="#DC2626"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="11"
                                Padding="8,4"
                                Margin="12,0,0,0"
                                BorderThickness="0"
                                VerticalAlignment="Stretch"
                                ToolTip="Only Fail Items - Show only items with fail status"
                                TabIndex="7"/>

                        <!-- REQ (Required Items Only) Toggle Button -->
                        <Button x:Name="ReqFilterButton"
                                Grid.Column="3"
                                Content="REQ"
                                Click="ReqFilterButton_Click"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="11"
                                Padding="8,4"
                                Margin="12,0,0,0"
                                BorderThickness="0"
                                VerticalAlignment="Stretch"
                                ToolTip="Required Items Only - Show only mandatory items (marked with *)"
                                TabIndex="8"/>

                        <!-- INC (Incomplete Items) Toggle Button -->
                        <Button x:Name="IncFilterButton"
                                Grid.Column="4"
                                Content="INC"
                                Click="IncFilterButton_Click"
                                Background="#D97706"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="11"
                                Padding="8,4"
                                Margin="12,0,0,0"
                                BorderThickness="0"
                                VerticalAlignment="Stretch"
                                ToolTip="Incomplete - Show only required items that are blank/incomplete"
                                TabIndex="9"/>
                    </Grid>

                    <ScrollViewer x:Name="TreeScrollViewer"
                                  Grid.Row="2" 
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PanningMode="VerticalOnly"
                                  CanContentScroll="False"
                                  PreviewMouseWheel="TreeScrollViewer_PreviewMouseWheel"
                                  PreviewMouseLeftButtonDown="TreeScrollViewer_PreviewMouseLeftButtonDown"
                                  PreviewMouseMove="TreeScrollViewer_PreviewMouseMove"
                                  PreviewMouseLeftButtonUp="TreeScrollViewer_PreviewMouseLeftButtonUp">
                        <Grid>
                        <TreeView x:Name="SectionsTreeView" 
                                  Background="Transparent" 
                                  BorderThickness="0"
                                  SelectedItemChanged="SectionsTreeView_SelectedItemChanged"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  ScrollViewer.CanContentScroll="False"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  Margin="5"
                                  TabIndex="10"
                                  KeyboardNavigation.TabNavigation="Once">
                            <TreeView.Resources>
                                <!-- Override system colors for TreeViewItem selection - TEAL with high contrast for outdoor visibility -->
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#4DB6AC"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#004D40"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#80CBC4"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#004D40"/>
                            </TreeView.Resources>
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="True"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Margin" Value="0,1"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TreeViewItem">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Border x:Name="Bd" Grid.Row="0"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="4,0,0,0"
                                                            Padding="4,3">
                                                        <ContentPresenter x:Name="PART_Header"
                                                                          ContentSource="Header"
                                                                          HorizontalAlignment="Stretch"/>
                                                    </Border>
                                                    <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="8,0,0,0"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="HasItems" Value="False">
                                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#004D40"/>
                                                        <Setter TargetName="Bd" Property="Background" Value="#E0F2F1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                        <StackPanel x:Name="InlineChecklistPanel"
                                    Visibility="Collapsed"
                                    Margin="5"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
            
            <!-- Bottom controls: docs + messages -->
            <StackPanel Grid.Row="1" Margin="5,2,5,5">
                <!-- Docs buttons -->
                <Grid Margin="5,0,5,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="PriorReportButton"
                            Grid.Column="0"
                            Content="◀ Prior"
                            Click="PriorReportButton_Click"
                            Background="#666"
                            Foreground="White"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Padding="10,8"
                            BorderThickness="0"
                            IsEnabled="False"
                            Visibility="Collapsed"
                            ToolTip="Open prior inspection report"
                            TabIndex="89"/>
                    <Button x:Name="MessagesButton"
                            Grid.Column="2"
                            Content="Messages"
                            Click="MessagesButton_Click"
                            Background="#555"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Padding="12,8"
                            ToolTip="View inspection messages again"
                            TabIndex="9"/>
                    <Button x:Name="SeeDocsButton"
                            Grid.Column="4"
                            Content="📄 See All PDFs"
                            Click="SeeDocsButton_Click"
                            Background="#2E86AB"
                            Foreground="White"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Padding="10,8"
                            BorderThickness="0"
                            IsEnabled="False"
                            ToolTip="Load an inspection to view documents (Alt+D)"
                            TabIndex="90"/>
                    <Button x:Name="SlabEngButton"
                            Grid.Column="6"
                            Content="Slab Eng"
                            Click="SlabEngButton_Click"
                            PreviewMouseRightButtonUp="SlabEngButton_PreviewMouseRightButtonUp"
                            Background="#8B5A2B"
                            Foreground="White"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Padding="12,8"
                            BorderThickness="0"
                            IsEnabled="False"
                            ToolTip="Open slab/foundation engineering PDF for this job"
                            TabIndex="91"/>
                </Grid>
            </StackPanel>
            </Grid>

            <!-- Right Panel - Item Editor -->
            <ScrollViewer x:Name="EditorScrollViewer"
                          Grid.Column="2" 
                          VerticalScrollBarVisibility="Hidden" 
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly"
                          CanContentScroll="False"
                          Padding="15"
                          PreviewMouseWheel="EditorScrollViewer_PreviewMouseWheel"
                          PreviewMouseLeftButtonDown="EditorScrollViewer_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="EditorScrollViewer_PreviewMouseMove"
                          PreviewMouseLeftButtonUp="EditorScrollViewer_PreviewMouseLeftButtonUp">
                <Grid>
                    <StackPanel x:Name="EditorPanel" Visibility="Collapsed">
                        
                        <!-- Item Header with Nav, slab info, and Duplicate Buttons -->
                        <Grid Margin="5,8,5,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="PrevItemButton" Content="◀" Click="PrevItemButton_Click" 
                                        Width="36" Height="28" FontSize="14" Margin="0,0,8,0"
                                        Background="#E8E8E8" BorderBrush="#CCC" ToolTip="Previous item"
                                        TabIndex="80"/>
                                <TextBlock x:Name="ItemNumberText" FontSize="16" FontWeight="Bold" Foreground="#8B0000" VerticalAlignment="Center"/>
                                <Button x:Name="NextItemButton" Content="▶" Click="NextItemButton_Click" 
                                        Width="36" Height="28" FontSize="14" Margin="8,0,0,0"
                                        Background="#E8E8E8" BorderBrush="#CCC" ToolTip="Next item"
                                        TabIndex="81"/>
                            </StackPanel>
                            <!-- CPP slab banner + EC banner (one visible at a time) -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,12,0">
                            <Border x:Name="SlabCableInfoHeaderBorder"
                                    Background="#FFF7E6"
                                    BorderBrush="#D9A441"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,5"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="EngDataBanner_Click"
                                    ToolTip="Click to see all extracted engineering data"
                                    Visibility="Collapsed">
                                <WrapPanel Orientation="Horizontal">
                                    <TextBlock x:Name="EngChip_Cables"
                                               FontSize="11" FontWeight="SemiBold" Foreground="#8B5A2B"
                                               Margin="0,0,10,0" Visibility="Collapsed"/>
                                    <TextBlock x:Name="EngChip_Slab"
                                               FontSize="11" FontWeight="SemiBold" Foreground="#8B5A2B"
                                               Margin="0,0,10,0" Visibility="Collapsed"/>
                                    <TextBlock x:Name="EngChip_Beam"
                                               FontSize="11" FontWeight="SemiBold" Foreground="#8B5A2B"
                                               Margin="0,0,10,0" Visibility="Collapsed"/>
                                    <TextBlock x:Name="EngChip_Holddowns"
                                               FontSize="11" FontWeight="SemiBold" Foreground="#8B5A2B"
                                               Margin="0,0,10,0" Visibility="Collapsed"/>
                                    <TextBlock x:Name="EngChip_Item"
