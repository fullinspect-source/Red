                                             Background="#E0E0E0"
                                             Foreground="#8B0000"/>
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="WelcomeHint"
                                   Text="Click 'Open INS' to get started" 
                                   FontSize="18" 
                                   Foreground="#777" 
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="HintTranslate" X="-300"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
