<Window x:Class="InspectionEditor.ResultPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Result"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="540"
        WindowStartupLocation="CenterOwner"
        Background="White"
        KeyDown="Window_KeyDown">

    <Border BorderBrush="#222" BorderThickness="2">
        <StackPanel>

            <!-- Header -->
            <Border Background="#1A1A1A" Padding="28,22">
                <StackPanel>
                    <TextBlock x:Name="InspTypeText"
                               Foreground="White" FontSize="24" FontWeight="Bold"/>
                    <TextBlock x:Name="SummaryText"
                               Foreground="#AAA" FontSize="15" Margin="0,7,0,0"/>
                </StackPanel>
            </Border>

            <!-- Result buttons — populated in code-behind -->
            <StackPanel x:Name="ButtonPanel" Margin="24,24,24,0"/>

            <!-- Skip / Keep Open row — always present, less prominent -->
            <Border Padding="24,14,24,26">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="SkipButton"
                            Grid.Column="0"
                            Content="— Skip: don't set a result now"
                            Click="SkipButton_Click"
                            Background="#EEEEEE"
                            Foreground="#666"
                            BorderThickness="0"
                            FontSize="15"
                            Padding="20,16"
                            HorizontalContentAlignment="Center"
                            Cursor="Hand"/>
                    <Button x:Name="KeepOpenButton"
                            Grid.Column="2"
                            Content="↩ Keep Open"
                            Click="KeepOpenButton_Click"
                            Background="#E3F2FD"
                            Foreground="#1565C0"
                            BorderBrush="#90CAF9"
                            BorderThickness="1"
                            FontSize="15"
                            Padding="20,16"
                            HorizontalContentAlignment="Center"
                            Cursor="Hand"/>
                </Grid>
            </Border>

        </StackPanel>
    </Border>
</Window>
