<Window x:Class="InspectionEditor.ImageEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Photo" 
        WindowState="Maximized"
        WindowStyle="None"
        Background="#222"
        KeyDown="Window_KeyDown">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Top Bar -->
        <Border Grid.Row="0" Background="#333" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="📷 Edit Photo" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                
                <!-- Adjustment indicators -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="BrightnessText" Text="Lift: 0%" Foreground="#FFD700" FontSize="14" Margin="20,0"/>
                    <TextBlock x:Name="SharpnessText" Text="Sharpness: 0%" Foreground="#00BFFF" FontSize="14" Margin="20,0"/>
                    <TextBlock x:Name="RotationText" Text="Rotate: 0°" Foreground="#888" FontSize="14" Margin="20,0"/>
                </StackPanel>
                
                <!-- Pen toggle -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ToggleButton x:Name="PenToggle" Content="✏️ Pen" 
                                  Checked="PenToggle_Changed" Unchecked="PenToggle_Changed"
                                  Background="#555" Foreground="White" 
                                  Padding="15,8" FontSize="14" BorderThickness="0" Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Image Area with InkCanvas overlay -->
        <Grid Grid.Row="1" x:Name="ImageContainer"
              TouchDown="ImageContainer_TouchDown"
              TouchMove="ImageContainer_TouchMove"
              TouchUp="ImageContainer_TouchUp"
              MouseDown="ImageContainer_MouseDown"
              MouseMove="ImageContainer_MouseMove"
              MouseUp="ImageContainer_MouseUp">
            
            <!-- The edited image -->
            <Image x:Name="PhotoImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
            
            <!-- InkCanvas for pen markup -->
            <InkCanvas x:Name="MarkupCanvas" 
                       Background="Transparent" 
                       EditingMode="None"
                       Opacity="1">
                <InkCanvas.DefaultDrawingAttributes>
                    <DrawingAttributes Color="Red" Width="4" Height="4" FitToCurve="True"/>
                </InkCanvas.DefaultDrawingAttributes>
            </InkCanvas>
            
            <!-- Gesture hint overlay -->
            <Border x:Name="GestureHint" Background="#80000000" Visibility="Collapsed" IsHitTestVisible="False">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="↑ Lift Shadows" Foreground="Yellow" FontSize="24" HorizontalAlignment="Center" Margin="0,10"/>
                    <TextBlock Text="→ Sharpen" Foreground="Cyan" FontSize="24" HorizontalAlignment="Center" Margin="0,10"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Rotation Slider -->
        <Border Grid.Row="2" Background="#2A2A2A" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="↺ -15°" Foreground="#666" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Slider x:Name="RotationSlider" Grid.Column="1"
                        Minimum="-15" Maximum="15" Value="0"
                        SmallChange="0.5" LargeChange="2" TickFrequency="1"
                        IsSnapToTickEnabled="False"
                        VerticalAlignment="Center"
                        ValueChanged="RotationSlider_ValueChanged"/>
                <TextBlock Grid.Column="2" Text="15° ↻" Foreground="#666" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- Bottom Bar -->
        <Border Grid.Row="3" Background="#333" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" x:Name="UndoButton" Content="↩️ Undo All" Click="UndoButton_Click"
                        Background="#E74C3C" Foreground="White" FontSize="16" FontWeight="SemiBold"
                        Padding="20,12" BorderThickness="0" HorizontalAlignment="Left" Margin="10,0"/>
                
                <TextBlock Grid.Column="1" Text="Swipe ↑ = Lift  |  Swipe → = Sharpen  |  Slider = Straighten  |  Pen = Markup"
                           Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click"
                            Background="#666" Foreground="White" FontSize="16"
                            Padding="20,12" BorderThickness="0" Margin="10,0"/>
                    <Button x:Name="SaveButton" Content="✓ Save" Click="SaveButton_Click"
                            Background="#27AE60" Foreground="White" FontSize="16" FontWeight="SemiBold"
                            Padding="25,12" BorderThickness="0" Margin="10,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
