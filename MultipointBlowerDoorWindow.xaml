<Window x:Class="InspectionEditor.MultipointBlowerDoorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RESNET 380 Multipoint Blower Door Test"
        Height="500" Width="560"
        MinHeight="460" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Ring radio button style — compact toggle feel -->
        <Style x:Key="RingButton" TargetType="RadioButton">
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="#E0E0E0" BorderBrush="#BDBDBD"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1565C0"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0D47A1"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#90CAF9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CFM entry TextBox style -->
        <Style x:Key="CfmBox" TargetType="TextBox">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Padding" Value="5,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="ANSI/RESNET/ICC 380 — Multipoint Blower Door Test"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="#1A237E" Margin="0,0,0,4"/>

        <TextBlock DockPanel.Dock="Top"
                   Text="Enter CFM readings from your blower door device at each RESNET pressure point. Select the ring used at each point."
                   FontSize="11" Foreground="#555" TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <!-- Target banner -->
        <Border DockPanel.Dock="Top"
                Background="#E3F2FD" BorderBrush="#90CAF9" BorderThickness="1"
                CornerRadius="4" Padding="10,6" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Target: " FontWeight="SemiBold" FontSize="12"/>
                <TextBlock x:Name="TargetLabel" FontSize="12" Foreground="#1565C0"/>
                <TextBlock Text="    ·    Single-point 90% threshold: " FontSize="12" Foreground="#555"/>
                <TextBlock x:Name="ThresholdLabel" FontSize="12" Foreground="#BF360C"/>
            </StackPanel>
        </Border>

        <!-- Bottom button bar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CalculateButton" Content="Calculate"
                    Width="90" Height="32" Margin="0,0,8,0"
                    Click="CalculateButton_Click"/>
            <Button x:Name="ApplyButton" Content="Apply to Report"
                    Width="120" Height="32" Margin="0,0,8,0"
                    IsEnabled="False"
                    Background="#2E7D32" Foreground="White" FontWeight="SemiBold"
                    Click="ApplyButton_Click"/>
            <Button Content="Cancel" Width="75" Height="32"
                    IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>

        <!-- Result strip -->
        <Border DockPanel.Dock="Bottom"
                x:Name="ResultBorder"
                Background="#F5F5F5" BorderBrush="#BDBDBD" BorderThickness="1"
                CornerRadius="4" Padding="10,7" Margin="0,8,0,0"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Multipoint cfm50 = " FontSize="13" FontWeight="SemiBold"/>
                <TextBlock x:Name="ResultCfm50Label" FontSize="13" FontWeight="Bold"
                           Foreground="#1A237E"/>
                <TextBlock x:Name="ResultNLabel" FontSize="11" Foreground="#555"
                           VerticalAlignment="Bottom" Margin="12,0,0,1"/>
                <TextBlock x:Name="ResultPassFailLabel" FontSize="12" FontWeight="Bold"
                           Margin="16,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Pressure point grid -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid x:Name="PointsGrid" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>    <!-- Pa label -->
                    <ColumnDefinition Width="*"/>     <!-- Ring buttons -->
                    <ColumnDefinition Width="100"/>   <!-- CFM box -->
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- 5 RESNET pressure points -->
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="44"/>
                </Grid.RowDefinitions>

                <!-- Column headers -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Pressure"
                           FontSize="11" FontWeight="SemiBold" Foreground="#555"
                           VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Ring used"
                           FontSize="11" FontWeight="SemiBold" Foreground="#555"
                           VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="CFM reading"
                           FontSize="11" FontWeight="SemiBold" Foreground="#555"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,4"/>

                <!-- Row 1: 60 Pa -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="60 Pa"
                           FontSize="13" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="4,0">
                    <RadioButton x:Name="Ring60A" Content="A" GroupName="Ring60"
                                 Style="{StaticResource RingButton}"/>
                    <RadioButton x:Name="Ring60B" Content="B" GroupName="Ring60"
                                 Style="{StaticResource RingButton}"/>
                    <RadioButton x:Name="Ring60C" Content="C" GroupName="Ring60"
                                 Style="{StaticResource RingButton}"/>
                </StackPanel>
                <TextBox x:Name="Cfm60" Grid.Row="1" Grid.Column="2"
                         Style="{StaticResource CfmBox}" VerticalAlignment="Center"
                         />

                <!-- Row 2: 48 Pa -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="48 Pa"
                           FontSize="13" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="4,0">
                    <RadioButton x:Name="Ring48A" Content="A" GroupName="Ring48"
                                 Style="{StaticResource RingButton}"/>
                    <RadioButton x:Name="Ring48B" Content="B" GroupName="Ring48"
                                 Style="{StaticResource RingButton}"/>
                    <RadioButton x:Name="Ring48C" Content="C" GroupName="Ring48"
                                 Style="{StaticResource RingButton}"/>
                </StackPanel>
                <TextBox x:Name="Cfm48" Grid.Row="2" Grid.Column="2"
                         Style="{StaticResource CfmBox}" VerticalAlignment="Center"
                         />

                <!-- Row 3: 35 Pa -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="35 Pa"
                           FontSize="13" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="4,0">
                    <RadioButton x:Name="Ring35A" Content="A" GroupName="Ring35"
                                 Style="{StaticResource RingButton}"/>
                    <RadioButton x:Name="Ring35B" Content="B" GroupName="Ring35"
                                 Style="{StaticResource RingButton}"/>
                    <RadioButton x:Name="Ring35C" Content="C" GroupName="Ring35"
                                 Style="{StaticResource RingButton}"/>
                </StackPanel>
                <TextBox x:Name="Cfm35" Grid.Row="3" Grid.Column="2"
                         Style="{StaticResource CfmBox}" VerticalAlignment="Center"
                         />

                <!-- Row 4: 23 Pa -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="23 Pa"
                           FontSize="13" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="4,0">
                    <RadioButton x:Name="Ring23A" Content="A" GroupName="Ring23"
                                 Style="{StaticResource RingButton}"/>
                    <RadioButton x:Name="Ring23B" Content="B" GroupName="Ring23"
                                 Style="{StaticResource RingButton}"/>
                    <RadioButton x:Name="Ring23C" Content="C" GroupName="Ring23"
                                 Style="{StaticResource RingButton}"/>
                </StackPanel>
                <TextBox x:Name="Cfm23" Grid.Row="4" Grid.Column="2"
                         Style="{StaticResource CfmBox}" VerticalAlignment="Center"
                         />

                <!-- Row 5: 10 Pa -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="10 Pa"
                           FontSize="13" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="4,0">
                    <RadioButton x:Name="Ring10A" Content="A" GroupName="Ring10"
                                 Style="{StaticResource RingButton}"/>
                    <RadioButton x:Name="Ring10B" Content="B" GroupName="Ring10"
                                 Style="{StaticResource RingButton}"/>
                    <RadioButton x:Name="Ring10C" Content="C" GroupName="Ring10"
                                 Style="{StaticResource RingButton}"/>
                </StackPanel>
                <TextBox x:Name="Cfm10" Grid.Row="5" Grid.Column="2"
                         Style="{StaticResource CfmBox}" VerticalAlignment="Center"
                         />
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
